@page "/"
@inject MudBlazor.IDialogService DialogService

<div class="row">
    
    @if (GetOrdersDtos == null || !GetOrdersDtos.Any())
    {
        <div class="col-md-4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Записи</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" @onclick="OpenDialog" Color="Color.Success" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText>Поки що немає записів. Створіть перший.</MudText>
                </MudCardContent>
            </MudCard>
        </div>
    }
    else
    {
        <div class="col-md-4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Записи</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" @onclick="OpenDialog" Color="Color.Success" />
                    </CardHeaderActions>
                </MudCardHeader>
                
                <MudCardContent>
                    <div class="row">
                        @foreach (var order in PendingOrders)
                        {
                            <div class="col-12 col-md-6 mb-4">
                                <OrderCard Order="@order"
                                           MoveToInProgress="MoveToInProgress"
                                           OnEdit="@(o => OpenDialog())"
                                           OnDelete="@(id => DeleteOrder(id))" />
                            </div>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </div>
    }

    <div class="col-md-4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">В процесі</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @foreach (var order in InProgressOrders)
                {
                    <div class="col-12 col-md-6 mb-4">
                        <OrderCard Order="@order"
                                   MoveToCompleted="MoveToCompleted"
                                   OnEdit="@(o => OpenDialog())"
                                   OnDelete="@(id => DeleteOrder(id))" />
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </div>

    <div class="col-md-4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Готово</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @foreach (var order in CompletedOrders)
                {
                    <div class="col-12 col-md-6 mb-4">
                        <OrderCard Order="@order"
                                   OnEdit="@(o => OpenDialog())"
                                   OnDelete="@(id => DeleteOrder(id))" />
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </div>
</div>

@code {
    private List<GetOrdersDto> PendingOrders => GetOrdersDtos?.Where(o => o.Status == OrderStatus.Pending).ToList() ?? new();
    private List<GetOrdersDto> InProgressOrders => GetOrdersDtos?.Where(o => o.Status == OrderStatus.InProgress).ToList() ?? new();
    private List<GetOrdersDto> CompletedOrders => GetOrdersDtos?.Where(o => o.Status == OrderStatus.Completed).ToList() ?? new();
    public List<GetOrdersDto>? GetOrdersDtos { get; set; }
    public List<Order> Orders { get; set; } = new();
    SaveOrderDto SaveOrderDto = new();
    OrderDialog? orderDialog;
    Order Order = new();

    protected override async Task OnInitializedAsync()
    {
        await GetOrders();
    }

    private async Task GetOrders()
    {
        GetOrdersDtos = await orderServiceDto.GetAllOrdersAsync(Constants.OrderBaseUrl);
    }

    void AddButtonClicked()
    {
        SaveOrderDto = new();
        OpenDialog();
    }

    private async Task HandleSaveOperationEvent(SaveOrderDto orderDto)
    {
        bool successCheck = false;
        if (orderDto.Id > 0)
        {
            var result = await orderServiceDto.Update(orderDto, Constants.OrderBaseUrl);
            successCheck = result != null;
        }
        else
        {
            var response = await orderServiceDto.InsertOrder(orderDto, Constants.OrderBaseUrl);
            successCheck = response != null;
        }
        if (successCheck)
        {
            Order = new();
            await GetOrders();
        }
    }

    private void OpenDialog()
    {
        var parameters = new DialogParameters
        {
            { "Order", SaveOrderDto },
            { "HandleSaveOperationEvent", EventCallback.Factory.Create<SaveOrderDto>(this, HandleSaveOperationEvent) }};

        var options = new DialogOptions
        {
            ClassBackground = "my-custom-class",
            MaxWidth = MaxWidth.Large,
            Position = DialogPosition.Center,
            FullWidth = true
        };

        DialogService.Show<OrderDialog>("Додати замовлення", parameters, options);
    }

    private async Task MoveToInProgress(int orderId)
    {
        await orderServiceDto.UpdateOrderStatusAsync(
            new UpdateOrderStatusDto
            {
                OrderId = orderId,
                Status = OrderStatus.InProgress
            },
            Constants.OrderBaseUrl
        );

        await GetOrders();
    }

    private async Task MoveToCompleted(int orderId)
    {
        await orderServiceDto.UpdateOrderStatusAsync(
            new UpdateOrderStatusDto
            {
                OrderId = orderId,
                Status = OrderStatus.Completed
            },
            Constants.OrderBaseUrl
        );

        await GetOrders();
    }

    private async Task DeleteOrder(int id)
    {
        await orderServiceDto.DeleteById(id, Constants.OrderBaseUrl);
        await GetOrders();
    }
}